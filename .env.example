# ── Client (Vite) ────────────────────────────────────────────────────────────
# URL of the Flask backend (no trailing slash)
# Development:  http://localhost:5000
# Production:   https://your-render-backend.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Web3Forms public access key (for the contact form)
# Get one free at https://web3forms.com
VITE_WEB3FORMS_KEY=your_web3forms_key_here

# ── Server (Flask) ────────────────────────────────────────────────────────────
# OpenAI API key — used for the WhyMe RAG pipeline (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Port the Flask server listens on (default: 5000)
PORT=5000

# Keepalive ping URL (APScheduler pings this to prevent Render cold starts)
# Set to the health-check endpoint of your deployed backend
# e.g. https://your-render-backend.onrender.com/api/health
HEALTH_URL=https://your-render-backend.onrender.com/api/health
